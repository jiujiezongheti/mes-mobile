{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uv-(.*)": "uview-plus/components/uv-$1/uv-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录"
      }
    },
    {
      "path": "pages/dashboard/index",
      "style": {
        "navigationBarTitleText": "MES",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "工单管理"
      }
    },
    {
      "path": "pages/task/index",
      "style": {
        "navigationBarTitleText": "作业任务"
      }
    },
    {
      "path": "pages/quality/index",
      "style": {
        "navigationBarTitleText": "质量检验"
      }
    },
    {
      "path": "pages/device/index",
      "style": {
        "navigationBarTitleText": "设备管理"
      }
    },
    {
      "path": "pages/stock/check",
      "style": {
        "navigationBarTitleText": "盘点录入"
      }
    },
    {
      "path": "pages/stock/check-task",
      "style": {
        "navigationBarTitleText": "盘点录入"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "MES",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "list": []
  }
}
